# 环境变量配置模板
# 复制此文件为 .env.local 并填入你的配置

# ========== AI 配置 ==========
# MiMo API 密钥 (必填)
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
AI_MODEL=mimo-v2.5-pro

# ========== 地图服务 ==========
# 高德地图 API Key (可选，用于天气查询)
AMAP_API_KEY=your-amap-api-key

# ========== 数据库 ==========
# PostgreSQL 连接字符串 (可选)
DATABASE_URL=postgresql://username:password@localhost:5432/elderly_assistant

# ========== 认证 ==========
# NextAuth Secret (可选)
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# ========== 语音服务 ==========
# 讯飞语音 API (可选，用于语音识别/合成)
IFLYTEK_APP_ID=your-iflytek-app-id
IFLYTEK_API_KEY=your-iflytek-api-key
IFLYTEK_API_SECRET=your-iflytek-api-secret
